{
    "name": "cline/ruler",
    "description": "Fluent rule engine with proposition-based evaluation and 50+ operators for building conditional business logic",
    "license": "MIT",
    "keywords": [
        "php",
        "rule-engine",
        "business-rules",
        "dsl",
        "fluent-interface",
        "proposition",
        "conditional-logic",
        "operators",
        "evaluation",
        "context"
    ],
    "authors": [
        {
            "name": "Brian Faust",
            "email": "brian@cline.sh"
        }
    ],
    "require": {
        "php": "^8.5.0",
        "mtdowling/jmespath.php": "^2.8",
        "symfony/expression-language": "^7.4.4"
    },
    "require-dev": {
        "cline/coding-standard": "^2.0.1",
        "ergebnis/composer-normalize": "^2.50.0",
        "orchestra/testbench": "^10.9",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-mutate": "^4.0.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.3",
        "symfony/var-dumper": "^7.4.6"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Cline\\Ruler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "benchmark:evaluator": "php tools/benchmark/rule-evaluator-benchmark.php",
        "lint": "ecs check --fix",
        "refactor": "rector",
        "test": [
            "@test:lint",
            "@test:type-coverage",
            "@test:unit",
            "@test:types",
            "@test:refactor",
            "@test:mutation-core"
        ],
        "test:lint": "ecs check",
        "test:mutation-core": "bash tools/ci/run-mutation-core.sh",
        "test:refactor": "rector --dry-run",
        "test:type-coverage": "pest --parallel --min=80 --type-coverage",
        "test:types": "phpstan",
        "test:unit": "pest --parallel --min=80 --coverage"
    }
}
